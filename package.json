{
  "name": "devcode",
  "version": "0.2.0",
  "description": "Minimal self-extensible TUI coding agent (Claude Code replica) in TypeScript + Ink + Bun",
  "keywords": ["coding-agent", "cli", "tui", "llm", "anthropic", "claude", "ink", "bun"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AEmad99/devcode.git"
  },
  "bugs": {
    "url": "https://github.com/AEmad99/devcode/issues"
  },
  "homepage": "https://github.com/AEmad99/devcode#readme",
  "type": "module",
  "bin": {
    "devcode": "./dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "files": ["dist", "docs", "src", "extensions", "README.md", "AGENTS.md", "package.json", "install.ps1", "install.cmd"],
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "build": "bun build ./src/index.ts --outdir dist --target node --external \"*/devtools.js\" && bun -e \"const f='dist/index.js';const t=await Bun.file(f).text();await Bun.write(f,t.replace(/^#!.*\\n/,'#!/usr/bin/env node\\n'))\"",
    "compile": "bun build --compile ./src/index.ts --outfile dist/devcode --external \"*/devtools.js\"",
    "prepare": "bun run build"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.52",
    "diff": "^9.0.0",
    "ink": "^7",
    "jiti": "^2.7.0",
    "react": "^19"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "typescript": "^7.0.2"
  }
}
